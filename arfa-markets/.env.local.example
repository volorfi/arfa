# ─────────────────────────────────────────────────────────────────────────────
# ARFA Markets — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.
#
# Railway note: set these under Service → Variables. Railway auto-injects
# PORT, RAILWAY_GIT_COMMIT_SHA, and RAILWAY_DEPLOYMENT_ID at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical site URL — Stripe success/cancel/return URLs, OAuth redirects,
# email links, the "absolute URL" helper, the sitemap host.
NEXT_PUBLIC_APP_URL=https://arfa.global
# Display name. Currently only read by a handful of marketing strings; wire
# it anywhere you see the literal "ARFA" if you decide to rebrand.
NEXT_PUBLIC_APP_NAME=ARFA

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project → Settings → API → Project URL + anon/public key + service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role key — server-only; NEVER expose to the browser. Used by admin
# tasks (webhook-driven user provisioning, impersonation, backfills).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Database (Supabase Postgres, Prisma connection string) ───────────────────
# Supabase → Settings → Database → Connection string → URI (with pooler).
# Prisma needs the direct connection for migrations; use `?pgbouncer=true&connection_limit=1`
# for serverless runtime, and a separate DIRECT_URL for `prisma migrate` locally.
DATABASE_URL=postgresql://postgres:<password>@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL (optional, used by `prisma migrate`)
# DIRECT_URL=postgresql://postgres:<password>@<direct-host>:5432/postgres

# ── Stripe ───────────────────────────────────────────────────────────────────
# Secret key — server-only. Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Publishable key — safe for the browser. Exposed via NEXT_PUBLIC_ so
# client components (future Stripe.js integrations) can read it without a
# server round-trip.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — from the dashboard after creating
# https://arfa.global/api/stripe/webhook as a webhook endpoint (or from
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` locally).
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — one per plan × interval. Create products + prices in
# the Stripe dashboard and paste the price IDs here. Server-only: the
# client sends {plan, interval} to /api/stripe/checkout and the server
# resolves the id. That keeps plan → price mappings tamper-proof.
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ── Stripe checkout / portal URLs ─────────────────────────────────────────────
# These are derived from NEXT_PUBLIC_APP_URL inside the server. Spelled out
# here so the deploy checklist matches what Stripe Dashboard wants:
#   Checkout success_url : https://arfa.global/dashboard?upgrade=success
#   Checkout cancel_url  : https://arfa.global/pricing
#   Portal return_url    : https://arfa.global/dashboard/settings
