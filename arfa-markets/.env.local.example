# ─────────────────────────────────────────────────────────────────────────────
# ARFA Markets — environment variables
# Copy this file to .env.local and fill in the values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project → Settings → API → Project URL + anon/public key + service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role key — server-only; NEVER expose to the browser. Used by admin
# tasks (webhook-driven user provisioning, impersonation, backfills).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Database (Supabase Postgres, Prisma connection string) ───────────────────
# Supabase → Settings → Database → Connection string → URI (with pooler).
# Prisma needs the direct connection for migrations; use `?pgbouncer=true&connection_limit=1`
# for serverless runtime, and a separate DIRECT_URL for `prisma migrate` locally.
DATABASE_URL="postgresql://postgres:<password>@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL (optional, used by `prisma migrate`)
# DIRECT_URL="postgresql://postgres:<password>@<direct-host>:5432/postgres"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# After `stripe listen --forward-to localhost:3000/api/stripe/webhook` or
# creating a webhook endpoint in the dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical site URL — used for Stripe success_url, OAuth callbacks, emails.
NEXT_PUBLIC_APP_URL=https://arfa.global
