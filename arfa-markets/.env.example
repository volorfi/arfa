# ─────────────────────────────────────────────────────────────────────────────
# ARFA Markets (arfa.global) — environment variables
# Copy to .env.local (dev) or set in Railway → Service → Variables (prod).
# Never commit your real .env file.
#
# Railway auto-injects PORT, RAILWAY_GIT_COMMIT_SHA, RAILWAY_DEPLOYMENT_ID.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Canonical site URL — Stripe success/cancel URLs, OAuth redirects, email
# links, the `absoluteUrl()` helper, and the sitemap host.
NEXT_PUBLIC_APP_URL=https://arfa.global
# Display name. Used in a handful of marketing strings. Rename if you rebrand.
NEXT_PUBLIC_APP_NAME=ARFA

# ── Supabase (auth + RLS-protected data) ─────────────────────────────────────
# Project → Settings → API → URL + anon/public key + service_role key.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Server-only; NEVER expose to the browser. Used by admin tasks (webhook-
# driven user provisioning, impersonation, backfills).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Database (Railway Postgres, Prisma) ──────────────────────────────────────
# Railway → Postgres service → Connect → Public Network → Show (or the
# internal `*.railway.internal` host if the app and DB share a project).
# No pgbouncer params needed — Railway's Postgres handles both pooled
# and non-pooled traffic on one port.
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# ── Stripe ───────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Publishable key — safe for the browser. Exposed via NEXT_PUBLIC_ so
# client components (e.g. Stripe.js) can read it without a server hop.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — Dashboard → Webhooks → arfa.global endpoint →
# Signing secret → Reveal. Not the `stripe listen` CLI secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — server-only so the plan → price map is tamper-proof.
# Client sends { plan, interval } to /api/stripe/checkout; server resolves.
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

#   Stripe Checkout success_url : https://arfa.global/dashboard?upgrade=success
#   Stripe Checkout cancel_url  : https://arfa.global/pricing
#   Stripe Portal  return_url   : https://arfa.global/dashboard/settings

# ── Google OAuth (optional — legacy /server surface) ─────────────────────────
# Currently unused by the Next.js app (Supabase handles auth). Kept so the
# ported /server services that may read ENV.googleClientId still work in
# edge cases.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM providers (ported services — news/sentiment/ideafarm/agent) ──────────
# Gemini for generic completion; Anthropic for the agent factor pipeline.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Resend) + owner inbox ─────────────────────────────────────────────
# https://resend.com → API Keys. Used by lib/notification.ts:notifyOwner().
RESEND_API_KEY=
# Where owner-facing notifications land (new sign-ups, contact form submits…).
OWNER_EMAIL=

# ── Object storage (optional — used by a small subset of ported services) ────
# S3-compatible. Empty means the storage-dependent services silently skip.
S3_BUCKET=
S3_ENDPOINT=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Legacy JWT (server-side cookies in the pre-Supabase era) ─────────────────
# Not read by the Next.js auth flow but kept for parity with deployed
# environments that still have it set.
JWT_SECRET=
