# Copy to .env and fill in. Never commit .env.

# --- Core ---
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# Used to sign session cookies and OAuth state. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Railway MySQL connection string.
DATABASE_URL=mysql://user:pass@host:3306/dbname

# --- Google OAuth 2.0 ---
# From Google Cloud Console → APIs & Services → Credentials.
# Authorised redirect URIs must include:
#   http://localhost:3000/api/auth/google/callback  (local dev)
#   https://arfa.markets/api/auth/google/callback   (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM providers ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
# https://resend.com → verify domain → create API key
RESEND_API_KEY=
# Contact-form notifications are delivered here; also becomes the auto-promoted admin.
OWNER_EMAIL=you@arfa.markets

# --- Object storage (AWS S3 or Cloudflare R2) ---
# Leave S3_ENDPOINT blank for AWS S3. For R2, use:
#   https://<account_id>.r2.cloudflarestorage.com
# and set AWS_REGION=auto.
S3_BUCKET=
S3_ENDPOINT=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
