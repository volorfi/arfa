# ─────────────────────────────────────────────────────────────────────────────
# ARFA Markets — Environment Variables
# Copy to .env and fill in. Never commit the filled-in file.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://arfa.markets        # no trailing slash

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=<random 64-char string>       # openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────────
# Railway:  mysql://user:password@containers-us-west-xxx.railway.app:PORT/railway
# AWS RDS:  mysql://user:password@xxx.rds.amazonaws.com:3306/arfa
DATABASE_URL=mysql://user:password@host:3306/arfa

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: https://arfa.markets/api/auth/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── LLM — Google Gemini ───────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── LLM — Anthropic (used by agentService for the multi-agent pipeline) ───────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Market data ───────────────────────────────────────────────────────────────
# Yahoo Finance is called directly — no API key needed

# ── Email notifications (contact form) ───────────────────────────────────────
# https://resend.com → API Keys (free: 3k emails/month)
# Also verify your sending domain in Resend dashboard
RESEND_API_KEY=re_xxx
OWNER_EMAIL=you@arfa.markets

# ── File storage (optional — only needed if using storagePut/storageGet) ──────
# AWS S3:
S3_BUCKET=arfa-assets
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxx
AWS_SECRET_ACCESS_KEY=xxx
# Cloudflare R2 (cheaper, no egress fees):
# S3_BUCKET=arfa-assets
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# AWS_REGION=auto
# AWS_ACCESS_KEY_ID=<R2 token id>
# AWS_SECRET_ACCESS_KEY=<R2 token secret>
